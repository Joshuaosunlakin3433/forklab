# ----------------------------------------------------------------------------
# forklab environment — copy this file to .env.local and fill in real values.
# .env.local is gitignored; this .env.example is committed and documents every
# variable the app reads. Never hardcode any of these values in source.
# ----------------------------------------------------------------------------

# --- MemForks (Git-for-AI-memory on Sui / Walrus) ---------------------------
# Object ID of your MemoryTree.
MEMFORK_TREE_ID=
# Sui signer private key (suiprivkey... bech32 string). Treated as the `signer`.
MEMFORK_PRIVATE_KEY=
# MemWal account id + delegate key (off-chain blob storage credentials).
MEMFORK_MEMWAL_ACCOUNT=
MEMFORK_MEMWAL_KEY=
# Sui network: mainnet | testnet | devnet | localnet
MEMFORK_NETWORK=mainnet
# MemWal relayer endpoint (maps to memwal.serverUrl). mainnet shown below.
MEMFORK_RELAYER_URL=https://relayer.memory.walrus.xyz
# Sponsor service for on-chain (branch) txs so they are gas-free (maps to the
# connect() `sponsorUrl` field). Without it, branch txs self-pay and fail.
MEMFORK_SPONSOR_URL=https://memforks-sponsor-production.up.railway.app/sponsor
# LangGraph checkpointer: on | off. OFF by default — its separate MemForksClient
# bypasses our MemWal throttle and eats rate limit while not yet load-bearing.
# Turn on for the consensus step when checkpoints are read back.
MEMFORK_CHECKPOINTER=off
# Optional: min ms between MemWal requests (throttle). Default 2200 (~27/min).
MEMWAL_MIN_INTERVAL_MS=2200

# --- Model provider (swappable via env, see src/lib/model.ts) ---------------
# groq | gemini | ollama   (only groq is implemented in this step)
MODEL_PROVIDER=groq
# Model id passed to the provider. llama-3.3-70b-versatile is a live Groq model.
MODEL_NAME=llama-3.3-70b-versatile
# Groq API key (Groq exposes an OpenAI-compatible endpoint).
GROQ_API_KEY=
# Optional fallback provider key — leave blank for now.
GEMINI_API_KEY=

# --- Dev-only mock backend --------------------------------------------------
# DEV HARNESS ONLY — never set this in production. Mocks /api/research and
# /api/merge with canned data so the frontend can be verified when the real
# backend services are down. Fires ONLY when NODE_ENV !== "production" AND
# MOCK_BACKEND === "on"; absent/anything-else => real routes run unchanged.
MOCK_BACKEND=off
